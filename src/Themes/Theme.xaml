<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- ====================================================================
         Paleta — Guía de estilos L5Argentina (pergamino oscuro / Rokugán).
         Estética: marrón casi negro, marfil cálido, rojo lacado, oro decorativo.
         ==================================================================== -->

    <!-- Base -->
    <Color x:Key="BackgroundDarkColor">#1B0A04</Color>
    <Color x:Key="TextPrimaryColor">#F8E6C1</Color>
    <Color x:Key="TextSecondaryColor">#BFA98A</Color>
    <Color x:Key="AccentRedColor">#7B1C1C</Color>
    <Color x:Key="AccentRedLightColor">#9E2E2E</Color>
    <Color x:Key="AccentRedDarkColor">#5A1414</Color>

    <!-- Superficies -->
    <Color x:Key="SurfaceDarkColor">#2A1008</Color>
    <Color x:Key="SurfaceVariantColor">#3A1A0C</Color>
    <Color x:Key="OutlineColorColor">#5A3020</Color>

    <!-- Inputs (invertidos: pergamino claro) -->
    <Color x:Key="InputBackgroundColor">#F8E6C1</Color>
    <Color x:Key="InputPlaceholderColor">#8A6A4A</Color>

    <!-- Oro decorativo -->
    <Color x:Key="GoldAccentColor">#C9A961</Color>
    <Color x:Key="GoldDimColor">#7A6432</Color>
    <Color x:Key="HighlightGoldColor">#FFD700</Color>

    <!-- Estado / utilidad -->
    <Color x:Key="DisabledTextColor">#7A6A5A</Color>
    <Color x:Key="BannedRedColor">#FF0000</Color>
    <Color x:Key="DangerRedColor">#E57373</Color>

    <!-- ===== Brushes ===== -->
    <SolidColorBrush x:Key="BackgroundDark" Color="{StaticResource BackgroundDarkColor}" />
    <SolidColorBrush x:Key="TextPrimary" Color="{StaticResource TextPrimaryColor}" />
    <SolidColorBrush x:Key="TextSecondary" Color="{StaticResource TextSecondaryColor}" />
    <SolidColorBrush x:Key="AccentRed" Color="{StaticResource AccentRedColor}" />
    <SolidColorBrush x:Key="AccentRedLight" Color="{StaticResource AccentRedLightColor}" />
    <SolidColorBrush x:Key="AccentRedDark" Color="{StaticResource AccentRedDarkColor}" />
    <SolidColorBrush x:Key="SurfaceDark" Color="{StaticResource SurfaceDarkColor}" />
    <SolidColorBrush x:Key="SurfaceVariant" Color="{StaticResource SurfaceVariantColor}" />
    <SolidColorBrush x:Key="OutlineColor" Color="{StaticResource OutlineColorColor}" />
    <SolidColorBrush x:Key="InputBackground" Color="{StaticResource InputBackgroundColor}" />
    <SolidColorBrush x:Key="InputPlaceholder" Color="{StaticResource InputPlaceholderColor}" />
    <SolidColorBrush x:Key="GoldAccent" Color="{StaticResource GoldAccentColor}" />
    <SolidColorBrush x:Key="GoldDim" Color="{StaticResource GoldDimColor}" />
    <SolidColorBrush x:Key="HighlightGold" Color="{StaticResource HighlightGoldColor}" />
    <SolidColorBrush x:Key="DisabledText" Color="{StaticResource DisabledTextColor}" />
    <SolidColorBrush x:Key="BannedRed" Color="{StaticResource BannedRedColor}" />
    <SolidColorBrush x:Key="DangerRed" Color="{StaticResource DangerRedColor}" />

    <!-- ===== Tipografía ===== -->
    <!-- L5RTitles: chrome de UI, títulos, labels de botón. Cuerpo: sans del sistema. -->
    <FontFamily x:Key="BrandFont">pack://application:,,,/Assets/Fonts/#L5RTitles</FontFamily>
    <FontFamily x:Key="BodyFont">Segoe UI</FontFamily>

    <!-- ===== Texturas de fondo ===== -->
    <ImageBrush x:Key="ParchmentBackground"
                ImageSource="pack://application:,,,/Assets/background.png"
                Stretch="UniformToFill" />

    <!-- ====================================================================
         Estilos de TextBlock (mapeo de la escala tipográfica de la guía)
         ==================================================================== -->
    <Style x:Key="HeadlineMedium" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource BrandFont}" />
        <Setter Property="FontSize" Value="30" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Ideal" />
    </Style>

    <Style x:Key="TitleMedium" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource BrandFont}" />
        <Setter Property="FontSize" Value="18" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
    </Style>

    <Style x:Key="SectionHeader" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource BrandFont}" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="Foreground" Value="{StaticResource GoldAccent}" />
    </Style>

    <Style x:Key="BodyMedium" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource BodyFont}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="BodySmall" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource BodyFont}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <!-- ====================================================================
         Botón primario (rojo lacado) — acción/selección
         ==================================================================== -->
    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="FontFamily" Value="{StaticResource BrandFont}" />
        <Setter Property="FontSize" Value="18" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
        <Setter Property="Background" Value="{StaticResource AccentRed}" />
        <Setter Property="Padding" Value="20,10" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="8"
                            BorderBrush="{StaticResource OutlineColor}"
                            BorderThickness="1"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource AccentRedLight}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource AccentRedDark}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource SurfaceVariant}" />
                            <Setter Property="Foreground" Value="{StaticResource DisabledText}" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Tarjeta de selección de base (RadioButton con apariencia de chip/card).
         Seleccionada = rojo lacado + borde oro; no seleccionada = SurfaceVariant + outline. -->
    <Style x:Key="BaseCard" TargetType="RadioButton">
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Border x:Name="bd" CornerRadius="12" BorderThickness="1"
                            Background="{StaticResource SurfaceVariant}"
                            BorderBrush="{StaticResource OutlineColor}"
                            Padding="18,16">
                        <ContentPresenter />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource GoldDim}" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource AccentRed}" />
                            <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource GoldAccent}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="bd" Property="Opacity" Value="0.45" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Botón secundario (ghost): borde, sin relleno fuerte -->
    <Style x:Key="GhostButton" TargetType="Button">
        <Setter Property="FontFamily" Value="{StaticResource BrandFont}" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
        <Setter Property="Background" Value="{StaticResource SurfaceVariant}" />
        <Setter Property="Padding" Value="14,8" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="6"
                            BorderBrush="{StaticResource OutlineColor}"
                            BorderThickness="1"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource SurfaceDark}" />
                            <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource GoldDim}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{StaticResource DisabledText}" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
