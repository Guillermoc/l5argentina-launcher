<Window
    x:Class="L5ArgentinaLauncher.Views.FirstRunWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Configuración inicial — L5Argentina Launcher"
    Width="600" Height="460"
    WindowStartupLocation="CenterScreen"
    ResizeMode="NoResize"
    Background="{StaticResource ParchmentBackground}">

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <Image Source="pack://application:,,,/Assets/logo_icon.png" Width="48" Height="48" Margin="0,0,14,0" />
            <TextBlock Text="Primer arranque" Style="{StaticResource HeadlineMedium}" VerticalAlignment="Center" />
        </StackPanel>

        <TextBlock Grid.Row="1" Style="{StaticResource BodyMedium}" Margin="0,0,0,18">
            Indicá dónde está instalado <Run FontWeight="Bold">Sun and Moon</Run>. Elegí el archivo
            <Run FontWeight="Bold">Sun and Moon.exe</Run> dentro de su carpeta de instalación.
            El launcher guardará una copia de seguridad de tu base actual como tu base
            <Run FontWeight="Bold">Original</Run>.
        </TextBlock>

        <Border Grid.Row="2" VerticalAlignment="Top"
                Background="{StaticResource SurfaceDark}" CornerRadius="12"
                BorderBrush="{StaticResource OutlineColor}" BorderThickness="1" Padding="18">
            <StackPanel>
                <TextBlock Text="Carpeta de Sun and Moon" Style="{StaticResource SectionHeader}" Margin="0,0,0,8" />
                <Border Background="{StaticResource InputBackground}" CornerRadius="6" Padding="10,8" Margin="0,0,0,12">
                    <TextBlock x:Name="PathText" Text="(sin seleccionar)"
                               Foreground="{StaticResource InputPlaceholder}" FontFamily="Segoe UI"
                               TextTrimming="CharacterEllipsis" />
                </Border>
                <Button x:Name="BrowseButton" Content="Elegir Sun and Moon.exe…"
                        Style="{StaticResource GhostButton}" HorizontalAlignment="Left"
                        Click="BrowseButton_Click" />
                <TextBlock x:Name="ValidationText" Style="{StaticResource BodySmall}"
                           Foreground="{StaticResource DangerRed}" Margin="0,12,0,0"
                           Visibility="Collapsed" TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="3" Margin="0,18,0,0">
            <Button x:Name="CancelButton" Content="Cancelar" Style="{StaticResource GhostButton}"
                    HorizontalAlignment="Left" MinWidth="110" Click="CancelButton_Click" />
            <Button x:Name="ContinueButton" Content="CONTINUAR" Style="{StaticResource PrimaryButton}"
                    HorizontalAlignment="Right" MinWidth="160" IsEnabled="False" Click="ContinueButton_Click" />
        </Grid>
    </Grid>
</Window>
