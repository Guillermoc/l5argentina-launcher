<Window
    x:Class="L5ArgentinaLauncher.Views.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Configuración — L5Argentina Launcher"
    Width="620" Height="420"
    WindowStartupLocation="CenterOwner"
    ResizeMode="NoResize"
    Background="{StaticResource ParchmentBackground}">

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Configuración" Style="{StaticResource HeadlineMedium}" Margin="0,0,0,16" />

        <StackPanel Grid.Row="1">
            <!-- Carpeta de Sun and Moon -->
            <TextBlock Text="Carpeta de Sun and Moon" Style="{StaticResource SectionHeader}" Margin="0,0,0,8" />
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="{StaticResource InputBackground}" CornerRadius="6" Padding="10,8">
                    <TextBlock x:Name="PathText" FontFamily="Segoe UI" Foreground="#2A1008"
                               TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                </Border>
                <Button Grid.Column="1" x:Name="BrowseButton" Content="Cambiar…"
                        Style="{StaticResource GhostButton}" Margin="10,0,0,0" Click="BrowseButton_Click" />
            </Grid>

            <!-- URL del manifest -->
            <TextBlock Text="URL del manifest" Style="{StaticResource SectionHeader}" Margin="0,18,0,8" />
            <TextBlock Style="{StaticResource BodySmall}" Margin="0,0,0,8"
                       Text="Debe ser HTTPS. Cambiala sólo si sabés lo que hacés (testing, migración de bucket o variante de la comunidad). El default apunta a nuestro bucket." />
            <Border Background="{StaticResource InputBackground}" CornerRadius="6" Padding="6,2">
                <TextBox x:Name="ManifestUrlBox" Background="Transparent" BorderThickness="0"
                         Foreground="#2A1008" FontFamily="Segoe UI" FontSize="13" VerticalContentAlignment="Center"
                         Height="28" />
            </Border>
            <Button x:Name="ResetUrlButton" Content="Restaurar URL por defecto"
                    Style="{StaticResource GhostButton}" HorizontalAlignment="Left" Margin="0,10,0,0"
                    Click="ResetUrlButton_Click" />

            <TextBlock x:Name="ValidationText" Style="{StaticResource BodySmall}"
                       Foreground="{StaticResource DangerRed}" Margin="0,12,0,0"
                       Visibility="Collapsed" TextWrapping="Wrap" />
        </StackPanel>

        <Grid Grid.Row="2" Margin="0,16,0,0">
            <Button x:Name="CancelButton" Content="Cancelar" Style="{StaticResource GhostButton}"
                    HorizontalAlignment="Left" MinWidth="110" Click="CancelButton_Click" />
            <Button x:Name="SaveButton" Content="GUARDAR" Style="{StaticResource PrimaryButton}"
                    HorizontalAlignment="Right" MinWidth="150" Click="SaveButton_Click" />
        </Grid>
    </Grid>
</Window>
