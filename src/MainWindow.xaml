<Window
    x:Class="L5ArgentinaLauncher.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="L5Argentina Launcher"
    Width="900" Height="640"
    MinWidth="780" MinHeight="560"
    WindowStartupLocation="CenterScreen"
    Background="{StaticResource ParchmentBackground}"
    Icon="pack://application:,,,/Assets/logo_icon.png"
    Loaded="Window_Loaded">

    <Grid Margin="28,24,28,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- header -->
            <RowDefinition Height="Auto" />  <!-- update banner -->
            <RowDefinition Height="*" />     <!-- contenido -->
            <RowDefinition Height="Auto" />  <!-- footer -->
            <RowDefinition Height="Auto" />  <!-- status -->
        </Grid.RowDefinitions>

        <!-- ===== Header ===== -->
        <Grid Grid.Row="0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Image Source="pack://application:,,,/Assets/logo_icon.png" Width="52" Height="52" Margin="0,0,16,0" />
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="L5Argentina Launcher" Style="{StaticResource HeadlineMedium}" />
                    <TextBlock Text="Legend of the Five Rings · Sun and Moon" Style="{StaticResource BodyMedium}" Margin="2,2,0,0" />
                </StackPanel>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button x:Name="RefreshButton" Content="Buscar actualizaciones" Style="{StaticResource GhostButton}"
                        Click="RefreshButton_Click" Margin="0,0,10,0" />
                <Button x:Name="SettingsButton" Content="Configuración" Style="{StaticResource GhostButton}"
                        Click="SettingsButton_Click" />
            </StackPanel>
        </Grid>

        <!-- ===== Banner de actualización del launcher ===== -->
        <Border x:Name="UpdateBanner" Grid.Row="1" Margin="0,16,0,0" Visibility="Collapsed"
                Background="{StaticResource AccentRedDark}" CornerRadius="10"
                BorderBrush="{StaticResource GoldAccent}" BorderThickness="1" Padding="16,12">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="●" Foreground="{StaticResource HighlightGold}" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0" />
                    <TextBlock x:Name="UpdateBannerText" Style="{StaticResource BodyMedium}" Foreground="{StaticResource TextPrimary}"
                               VerticalAlignment="Center" Text="Hay una versión nueva del launcher." />
                </StackPanel>
                <Button x:Name="UpdateLinkButton" Content="Ir a descargas" Style="{StaticResource GhostButton}"
                        HorizontalAlignment="Right" Click="UpdateLinkButton_Click" />
            </Grid>
        </Border>

        <!-- ===== Contenido ===== -->
        <ScrollViewer Grid.Row="2" Margin="0,20,0,0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Selección de base -->
                <TextBlock Text="Elegí con qué base jugar" Style="{StaticResource SectionHeader}" Margin="0,0,0,12" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <RadioButton x:Name="CommunityCard" Grid.Column="0" GroupName="base"
                                 Style="{StaticResource BaseCard}" Checked="BaseCard_Checked">
                        <StackPanel>
                            <TextBlock Text="Comunidad" Style="{StaticResource TitleMedium}" />
                            <TextBlock Text="Base curada L5Argentina (s_extended)" Style="{StaticResource BodySmall}" Foreground="{StaticResource TextPrimary}" Margin="0,4,0,0" />
                            <TextBlock x:Name="CommunityVersionText" Style="{StaticResource BodySmall}" Margin="0,8,0,0" Text="Versión: —" />
                            <TextBlock x:Name="CommunityStatusText" Style="{StaticResource BodySmall}" Foreground="{StaticResource HighlightGold}" Margin="0,2,0,0" Text="" />
                        </StackPanel>
                    </RadioButton>

                    <RadioButton x:Name="OriginalCard" Grid.Column="2" GroupName="base"
                                 Style="{StaticResource BaseCard}" Checked="BaseCard_Checked">
                        <StackPanel>
                            <TextBlock Text="Original" Style="{StaticResource TitleMedium}" />
                            <TextBlock Text="Tu base sin nuestras modificaciones" Style="{StaticResource BodySmall}" Foreground="{StaticResource TextPrimary}" Margin="0,4,0,0" />
                            <TextBlock x:Name="OriginalStatusText" Style="{StaticResource BodySmall}" Margin="0,8,0,0" Text="Respaldo local del primer arranque" />
                        </StackPanel>
                    </RadioButton>
                </Grid>

                <!-- Imágenes propias -->
                <Border Margin="0,18,0,0" Background="{StaticResource SurfaceDark}" CornerRadius="10"
                        BorderBrush="{StaticResource OutlineColor}" BorderThickness="1" Padding="16,12">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Imágenes propias:" Style="{StaticResource BodyMedium}" Foreground="{StaticResource TextPrimary}" Margin="0,0,8,0" />
                        <TextBlock x:Name="ImagesStatusText" Style="{StaticResource BodyMedium}" Text="—" />
                    </StackPanel>
                </Border>

                <!-- Noticias (placeholder v2) -->
                <TextBlock Text="Noticias y torneos" Style="{StaticResource SectionHeader}" Margin="0,22,0,8" />
                <Border Background="{StaticResource SurfaceDark}" CornerRadius="10"
                        BorderBrush="{StaticResource OutlineColor}" BorderThickness="1" Padding="16,18">
                    <TextBlock x:Name="NewsPlaceholder" Style="{StaticResource BodyMedium}"
                               Text="Próximamente: novedades de la comunidad e info de torneos." />
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- ===== Footer ===== -->
        <Grid Grid.Row="3" Margin="0,18,0,0">
            <StackPanel VerticalAlignment="Center">
                <TextBlock x:Name="InstallPathText" Style="{StaticResource BodySmall}" Text="" TextTrimming="CharacterEllipsis" MaxWidth="520" HorizontalAlignment="Left" />
                <TextBlock x:Name="LauncherVersionText" Style="{StaticResource BodySmall}" Foreground="{StaticResource GoldDim}" Margin="0,2,0,0" />
            </StackPanel>
            <Button x:Name="PlayButton" Content="JUGAR" Style="{StaticResource PrimaryButton}"
                    HorizontalAlignment="Right" MinWidth="200" FontSize="22" Padding="24,12"
                    Click="PlayButton_Click" />
        </Grid>

        <!-- ===== Status / progreso ===== -->
        <Grid Grid.Row="4" Margin="0,14,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <TextBlock x:Name="StatusText" Grid.Row="0" Style="{StaticResource BodySmall}" Text="Inicializando…" />
            <ProgressBar x:Name="Progress" Grid.Row="1" Height="6" Margin="0,8,0,0"
                         Background="{StaticResource SurfaceVariant}" Foreground="{StaticResource AccentRed}"
                         BorderThickness="0" Visibility="Collapsed" />
        </Grid>
    </Grid>
</Window>
